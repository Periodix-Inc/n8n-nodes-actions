{
    "name": "@periodix/n8n-nodes-actions",
    "version": "1.1.0",
    "description": "n8n community nodes for the Periodix Actions API",
    "license": "MIT",
    "homepage": "https://periodix.net",
    "keywords": [
        "n8n-community-node-package",
        "periodix",
        "linkedin",
        "sales-navigator",
        "sales",
        "outreach"
    ],
    "author": {
        "name": "Vadym Gidulian",
        "email": "vadym.gidulian@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Periodix-Inc/n8n-nodes-actions.git"
    },
    "scripts": {
        "build": "n8n-node build",
        "build:watch": "tsc --watch",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "release": "n8n-node release",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": [
        "dist"
    ],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": [
            "dist/credentials/PeriodixActionsApi.credentials.js"
        ],
        "nodes": [
            "dist/nodes/LinkedInSearch/LinkedInSearch.node.js",
            "dist/nodes/LinkedInGetProfile/LinkedInGetProfile.node.js",
            "dist/nodes/LinkedInGetCompanyProfile/LinkedInGetCompanyProfile.node.js",
            "dist/nodes/LinkedInGetUserPosts/LinkedInGetUserPosts.node.js",
            "dist/nodes/LinkedInGetPostComments/LinkedInGetPostComments.node.js",
            "dist/nodes/LinkedInGetPostReactions/LinkedInGetPostReactions.node.js",
            "dist/nodes/LinkedInGetConnections/LinkedInGetConnections.node.js"
        ]
    },
    "devDependencies": {
        "@n8n/node-cli": "0.30.1",
        "eslint": "9.39.4",
        "prettier": "3.8.3",
        "release-it": "19.2.4",
        "typescript": "5.9.3"
    },
    "peerDependencies": {
        "n8n-workflow": "2.16.0"
    },
    "packageManager": "pnpm@10.33.2"
}
